#include <stdio.h>
#include <stdlib.h>

// Прототипы функций, чтобы компилятор знал о них заранее
int* Merge(int* A, int* B, size_t n1, size_t n2);
void PrintArray(int* A, size_t n);

void MergeSort(int* A, size_t n)
{
    // Базовый случай: 0 или 1 элемент уже отсортированы
    if (n <= 1) return;

    // Оптимизация: если элементов ровно два, просто меняем их местами
    if (n == 2) 
    {
        if (A[0] > A[1]) 
        {
            int temp = A[0];
            A[0] = A[1];
            A[1] = temp;
        }
    }
    else 
    {
        // Делим массив на две части
        size_t n1 = n / 2;
        size_t n2 = n - n1;

        // Выделяем память под две временные половинки (в Си используем malloc)
        int* B = (int*)malloc(n1 * sizeof(int));
        int* C = (int*)malloc(n2 * sizeof(int));

        // Копируем элементы в левую половинку
        for (size_t i = 0; i < n1; i++)
        {
            B[i] = A[i];
        }

        // Копируем элементы в правую половинку
        for (size_t i = 0; i < n2; i++)
        {
            C[i] = A[i + n1];
        }

        // Рекурсивно сортируем каждую половинку
        MergeSort(B, n1);
        MergeSort(C, n2);

        // Сливаем отсортированные половинки в один новый массив
        int* merged = Merge(B, C, n1, n2);

        // Копируем результат слияния обратно в наш исходный массив A
        for (size_t i = 0; i < n; i++)
        {
            A[i] = merged[i];
        }

        // Чистим за собой память (в Си используем free)
        free(B);
        free(C);
        free(merged);
    }
}

int* Merge(int* A, int* B, size_t n1, size_t n2)
{
    size_t n3 = n1 + n2;
    // Выделяем память под результирующий массив
    int* C = (int*)malloc(n3 * sizeof(int)); 

    size_t pointerA = 0;
    size_t pointerB = 0;
    size_t pointerC = 0;

    // Главный цикл слияния: пока в обоих массивах есть элементы
    while (pointerA < n1 && pointerB < n2)
    {
        if (A[pointerA] <= B[pointerB])
        {
            C[pointerC] = A[pointerA];
            pointerA++;
        }
        else
        {
            C[pointerC] = B[pointerB];
            pointerB++;
        }
        pointerC++;
    }

    // Если массив B закончился, а в A еще остались элементы — дописываем их
    while (pointerA < n1)
    {
        C[pointerC] = A[pointerA];
        pointerA++;
        pointerC++;
    }

    // Если массив A закончился, а в B еще остались элементы — дописываем их
    while (pointerB < n2)
    {
        C[pointerC] = B[pointerB];
        pointerB++;
        pointerC++;
    }

    // Показываем промежуточный этап слияния
    PrintArray(C, n3);

    return C;
}

void PrintArray(int* A, size_t n) 
{
    for (size_t i = 0; i < n; i++) 
    {
        printf("%d ", A[i]);
    }
    printf("\n");
}

int main() 
{                               
    int my_array[] = { 5, 1, 3, 8, 9, 1, 2 };  
    size_t size = sizeof(my_array) / sizeof(my_array[0]);
                                  
    printf("Исходный массив:\n");
    PrintArray(my_array, size);
    
    printf("\nПроцесс слияния элементов:\n");
    MergeSort(my_array, size);
    
    printf("\nОтсортированный массив:\n");
    PrintArray(my_array, size);

    return 0;
}
